{
  "headers": [
    {
      "source": "/api/webhook",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "X-Requested-With, Content-Type, Accept, stripe-signature" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/auto-mark",
      "schedule": "0 21 * * 0,6"
    }
  ],
  "rewrites": [],
  "redirects": []
}
